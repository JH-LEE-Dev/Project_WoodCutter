# --- Godot 자동 생성 및 캐시 폴더 ---
.godot/                # 고도 4.x의 핵심 캐시 폴더 (유니티의 Library와 같음)
*.import/              # 에셋 임포트 관련 데이터
export_preset.cfg      # 빌드 설정 (비밀번호 등이 포함될 수 있음)

# --- C# (.NET) 관련 빌드 및 캐시 ---
.mono/                 # 고도 3.x용 (하위 호환)
.pck/
.pck.tmp
[Bb]in/                # 컴파일된 바이너리
[Oo]bj/                # 컴파일 중간 파일
*.sln                  # 솔루션 파일 (고도가 자동 생성함)
*.csproj               # 프로젝트 파일 (고도가 자동 생성함)

# --- IDE 설정 (VS Code / Visual Studio) ---
.vscode/               # VS Code 개인 설정
.vs/                   # Visual Studio 캐시
*.user                 # 사용자별 프로젝트 설정
*.userprefs

# --- 고도 MCP 및 외부 플러그인 (필요시 제외) ---
# addons/ 폴더 전체를 제외하고 싶다면 아래 주석을 해제하세요.
# 하지만 보통 인디 팀에서는 addons를 포함해서 공유하는 편입니다.
# addons/godot-mcp/

# --- 대용량 바이너리 및 미디어 ---
# 유니티와 마찬가지로 소스 제어에 포함하지 않을 확장자들
*.png
*.jpg
*.jpeg
*.tga
*.psd
*.svg                  # 고도는 아이콘으로 svg를 많이 씁니다. 필요시 제외.
*.fbx
*.obj
*.glb                  # 고도에서 권장하는 3D 포맷
*.gltf
*.wav
*.mp3
*.ogg                  # 고도에서 권장하는 오디오 포맷
*.ttf
*.otf

# --- 고도 전용 바이너리 씬/리소스 ---
# 텍스트 기반(.tscn, .tres)은 포함하고, 바이너리(.scn, .res)는 제외하는 설정
*.scn
*.res